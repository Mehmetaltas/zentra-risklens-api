// ZENTRA Signal Engine
// Global risk skorunu hesaplayan ilk motor

import { loadSources } from "../data/source-registry.js"

export function calculateGlobalRisk() {

  const sources = loadSources()

  let oil = sources.energy[0].value
  let container = sources.logistics[0].value
  let inflation = sources.finance[0].value
  let cyber = sources.cyber[0].value

  let riskScore = 0
  let drivers = []

  // Oil pressure
  if (oil > 80) {
    riskScore += 25
    drivers.push("Oil shock")
  }

  // Logistics pressure
  if (container > 2000) {
    riskScore += 20
    drivers.push("Logistics stress")
  }

  // Inflation pressure
  if (inflation > 4) {
    riskScore += 20
    drivers.push("Inflation pressure")
  }

  // Cyber risk
  if (cyber > 50) {
    riskScore += 15
    drivers.push("Cyber threat")
  }

  if (riskScore > 100) riskScore = 100

  return {
    riskScore,
    dominantDriver: drivers[0] || "Stable conditions",
    signals: drivers
  }
} 
